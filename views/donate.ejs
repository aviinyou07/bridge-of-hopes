<form id="payuForm" method="post" class="hidden"></form>

<script>
    const ENABLE_CLIENT_LOGS = false;
    const clientLogger = {
        error: (...args) => {
            if (ENABLE_CLIENT_LOGS) {
                console.error(...args);
            }
        }
    };

    let baseAmount = 0;
    let finalAmount = 0;
    let donationType = 'once';

    function setAmount(amount, element) {
        baseAmount = Number(amount) || 0;
        calculateFinal();
        updateUI();
        highlightButton(element);
    }

    function handleInput(value) {
        const numericValue = Number(value) || 0;

        if (donationType === 'monthly') {
            baseAmount = numericValue / 12;
        } else {
            baseAmount = numericValue;
        }

        calculateFinal();
        updateUI();
        clearPresetHighlight();
    }

    function calculateFinal() {
        if (donationType === 'monthly') {
            finalAmount = Math.round(baseAmount * 12);
        } else {
            finalAmount = Math.round(baseAmount);
        }
    }

    function updateUI() {
        document.getElementById('customAmount').value = finalAmount;

        const meals = Math.floor(finalAmount / 50);
        document.getElementById('mealCount').innerText = meals;

        document.getElementById('mealFrequencyText').innerText =
            donationType === 'monthly'
                ? ` (₹${finalAmount} for 12 months total)`
                : '';
    }

    function highlightButton(element) {
        clearPresetHighlight();
        if (element) {
            element.classList.add('bg-green-600', 'text-white', 'border-green-600');
            element.classList.remove('border-gray-300');
        }
    }

    function clearPresetHighlight() {
        document.querySelectorAll('.amt-btn').forEach((btn) => {
            btn.classList.remove('bg-green-600', 'text-white', 'border-green-600');
            btn.classList.add('border-gray-300');
        });
    }

    // Modal Control
    function openDonorModal() {
            if (finalAmount < 500) {
            alert("Please enter a valid donation amount (minimum ₹500)");
            return;
        }
                document.getElementById('modalAmountDisplay').innerText = finalAmount;
                document.getElementById('donorModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Prevent scroll
    }

    function closeDonorModal() {
        document.getElementById('donorModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // API & Payment Execution
    async function triggerPaymentFlow() {
        const donorData = {
            name: document.getElementById('donorName').value.trim(),
            email: document.getElementById('donorEmail').value.trim(),
            phone: document.getElementById('donorPhone').value.trim(),
            amount: finalAmount,
            type: donationType,
        };

        if (!donorData.name || !donorData.email || donorData.phone.length < 10) {
            alert("Please provide valid contact information.");
            return;
        }

        const payBtn = document.getElementById('payFinalBtn');
        payBtn.innerText = "REDIRECTING...";
        payBtn.disabled = true;

        try {
            const response = await fetch("/donate", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(donorData)
            });

            if (!response.ok) {
                let serverMessage = "Server error";
                try {
                    const errorPayload = await response.json();
                    if (errorPayload && errorPayload.error) {
                        serverMessage = errorPayload.error;
                    }
                } catch (_) {
                    serverMessage = `Server error (${response.status})`;
                }
                throw new Error(serverMessage);
            }

            const data = await response.json();
            const form = document.getElementById("payuForm");
            form.action = data.action;
            form.innerHTML = ''; // Clear previous fields

            // Map PayU parameters to hidden inputs
            for (const key in data.params) {
                const input = document.createElement("input");
                input.type = "hidden";
                input.name = key;
                input.value = data.params[key];
                form.appendChild(input);
            }

            form.submit();
        } catch (error) {
            clientLogger.error("Payment failed:", error);
            alert(`Could not connect to payment gateway: ${error.message}`);
            payBtn.innerText = `PAY ₹${finalAmount} NOW`;
            payBtn.disabled = false;
        }
    }

    function toggleDonationType(type) {
        const onceBtn = document.getElementById('giveOnceBtn');
        const monthlyBtn = document.getElementById('giveMonthlyBtn');
        donationType = type === 'monthly' ? 'monthly' : 'once';
        
        if (type === 'once') {
            onceBtn.className = "flex-1 py-3 bg-[#4db748] text-white font-bold transition-colors";
            monthlyBtn.className = "flex-1 py-3 bg-white text-black border-l font-bold transition-colors";
        } else {
            monthlyBtn.className = "flex-1 py-3 bg-[#4db748] text-white font-bold transition-colors";
            onceBtn.className = "flex-1 py-3 bg-white text-black border-r font-bold transition-colors";
        }

        calculateFinal();
        updateUI();
    }

    function closePaymentResultModal() {
        document.getElementById('paymentResultModal').classList.add('hidden');
        document.body.style.overflow = 'auto';

        const params = new URLSearchParams(window.location.search);
        params.delete('paymentStatus');
        params.delete('txnid');
        params.delete('gatewayTxnId');
        params.delete('paymentMode');
        params.delete('bankRef');
        params.delete('amount');
        params.delete('name');
        params.delete('email');
        params.delete('message');
        params.delete('paidAt');

        const cleanedQuery = params.toString();
        const nextUrl = cleanedQuery ? `/donate?${cleanedQuery}` : '/donate';
        window.history.replaceState({}, '', nextUrl);
    }

    function openShareModal() {
        document.getElementById('shareModal').classList.remove('hidden');
        document.getElementById('shareModal').classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeShareModal() {
        const shareModal = document.getElementById('shareModal');
        shareModal.classList.add('hidden');
        shareModal.classList.remove('flex');
        document.body.style.overflow = 'auto';
    }

    function getShareText() {
        return 'I am supporting India\'s children through Bridge of Hopes. Join me in making a difference.';
    }

    function getShareUrl() {
        return `${window.location.origin}/donate`;
    }

    function shareOnWhatsApp() {
        const whatsappText = `${getShareText()} ${getShareUrl()}`;
        const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(whatsappText)}`;
        window.open(whatsappUrl, '_blank');
    }

    async function copyShareText() {
        const shareContent = `${getShareText()} ${getShareUrl()}`;
        const copyBtn = document.getElementById('copyShareBtn');
        const originalText = copyBtn.innerHTML;

        try {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(shareContent);
            } else {
                const textArea = document.createElement('textarea');
                textArea.value = shareContent;
                textArea.style.position = 'fixed';
                textArea.style.opacity = '0';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
            }

            copyBtn.innerHTML = '<i class="fa-solid fa-check"></i> Copied';
            setTimeout(() => {
                copyBtn.innerHTML = originalText;
            }, 1200);
        } catch (_) {
            alert('Copy failed. Please copy manually from browser address bar.');
        }
    }

    function formatAmount(amount) {
        const numericAmount = Number(amount) || 0;
        return `₹${new Intl.NumberFormat('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(numericAmount)}`;
    }

    function openPaymentResultModal(result) {
        const isSuccess = result.paymentStatus === 'success';
        const header = document.getElementById('paymentResultHeader');
        const badge = document.getElementById('paymentStatusBadge');
        const subtext = document.getElementById('paymentResultSubtext');

        if (isSuccess) {
            header.className = 'px-6 py-4 text-white bg-green-600';
            badge.className = 'text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-green-100 text-green-700';
            badge.innerText = 'Success';
            subtext.innerText = 'Your donation has been received successfully.';
        } else {
            header.className = 'px-6 py-4 text-white bg-red-600';
            badge.className = 'text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-red-100 text-red-700';
            badge.innerText = 'Failed';
            subtext.innerText = 'Your donation could not be completed.';
        }

        document.getElementById('paymentAmount').innerText = formatAmount(result.amount);
        document.getElementById('paymentDateTime').innerText = result.paidAt
            ? new Date(result.paidAt).toLocaleString('en-IN')
            : new Date().toLocaleString('en-IN');
        document.getElementById('paymentTxnId').innerText = result.txnid || '-';
        document.getElementById('paymentGatewayTxnId').innerText = result.gatewayTxnId || '-';
        document.getElementById('paymentMode').innerText = result.paymentMode || '-';
        document.getElementById('paymentBankRef').innerText = result.bankRef || '-';
        document.getElementById('paymentDonor').innerText = result.name || '-';
        document.getElementById('paymentEmail').innerText = result.email || '-';
        document.getElementById('paymentMessage').innerText = result.message || 'Transaction status received from payment gateway.';

        document.getElementById('paymentResultModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    (function hydratePageFromQuery() {
        const params = new URLSearchParams(window.location.search);
        const amount = Number(params.get('amount')) || 0;
        const type = params.get('type');

        if (type === 'monthly' || type === 'once') {
            toggleDonationType(type);
        }

        if (amount > 0) {
            document.getElementById('customAmount').value = amount;
            handleInput(amount);
        }

        const paymentStatus = params.get('paymentStatus');
        if (paymentStatus === 'success' || paymentStatus === 'failed') {
            openPaymentResultModal({
                paymentStatus,
                txnid: params.get('txnid'),
                amount: params.get('amount'),
                gatewayTxnId: params.get('gatewayTxnId'),
                paymentMode: params.get('paymentMode'),
                bankRef: params.get('bankRef'),
                name: params.get('name'),
                email: params.get('email'),
                message: params.get('message'),
                paidAt: params.get('paidAt'),
            });
        }
    })();
</script>

