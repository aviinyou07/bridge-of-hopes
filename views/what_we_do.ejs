<%- include('partials/header')%>
     <div class="max-w-6xl mx-auto mt-8 p-2">
        
        <header class="border-b-4 border-red-primary pb-6 mb-10">
            <h1 class="text-5xl font-bold text-red-primary">Bridge of Hopes</h1>
            <p class="text-xl text-gray-600 mt-2 font-light">Strategic Journey 2025-2027 | <span class="font-bold text-gray-800">Save the Children India</span></p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            
            <section>
                <h2 class="text-3xl font-bold mb-4 text-gray-800">Our Profile</h2>
                <p class="text-gray-700 leading-relaxed mb-6">
                    Bridge of Hopes (also known as Save the Children) is a registered entity under the Societies Registration Act 1860, working in India since 2004. We are one of the country's leading organisations working for and with children, in alignment with the government's mission.
                </p>
                
                <div class="grid grid-cols-3 gap-4 mb-8">
                    <div class="bg-red-primary text-white p-4 rounded text-center">
                        <div class="text-2xl font-bold">35 Lakh</div>
                        <div class="text-xs uppercase">Children Impacted</div>
                    </div>
                    <div class="bg-blue-500 text-white p-4 rounded text-center">
                        <div class="text-2xl font-bold">234</div>
                        <div class="text-xs uppercase">Projects</div>
                    </div>
                    <div class="bg-purple-600 text-white p-4 rounded text-center">
                        <div class="text-2xl font-bold">160</div>
                        <div class="text-xs uppercase">Institutional Donors</div>
                    </div>
                </div>

                <div class="bg-gray-100 p-6 border-l-8 border-red-primary">
                    <h3 class="text-xl font-bold mb-2">Our Vision Statement</h3>
                    <p class="italic text-gray-600">
                        "To positively impact the lives of children in India and to ensure full participation of Bridge of Hopes with all stakeholders, in the journey of developed India (Viksit Bharat)—where every child enjoys a healthy, nourished, protected, and inclusive childhood, to fulfill their aspirations."
                    </p>
                </div>
            </section>

            <section>
                <h2 class="text-3xl font-bold mb-6 text-gray-800">2030: Breakthroughs</h2>
                <div class="space-y-4">
                    <div class="flex items-center p-4 border rounded-lg hover:shadow-md transition">
                        <div class="text-4xl mr-4 text-pink-500">✚</div>
                        <div>
                            <h4 class="font-bold heading-font text-pink-500">Survive</h4>
                            <p class="text-sm">No child dies from preventable causes before their 5th birthday.</p>
                        </div>
                    </div>
                    <div class="flex items-center p-4 border rounded-lg hover:shadow-md transition">
                        <div class="text-4xl mr-4 text-blue-400">📖</div>
                        <div>
                            <h4 class="font-bold heading-font text-blue-400">Learn</h4>
                            <p class="text-sm">All children learn from a quality basic education.</p>
                        </div>
                    </div>
                    <div class="flex items-center p-4 border rounded-lg hover:shadow-md transition">
                        <div class="text-4xl mr-4 text-orange-600">🛡️</div>
                        <div>
                            <h4 class="font-bold heading-font text-orange-600">Be Protected</h4>
                            <p class="text-sm">Violence against children is no longer tolerated.</p>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <section class="mt-16">
            <h2 class="text-3xl font-bold mb-8 text-center bg-gray-800 text-white py-2">Strategic Goals (2025-2027)</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="border-t-4 border-custom-green p-4 bg-gray-50">
                    <h3 class="font-bold text-custom-green mb-2">Health & Nutrition</h3>
                    <ul class="text-sm space-y-2 text-gray-700">
                        <li>• Life cycle interventions for maternal/child health.</li>
                        <li>• Targeting 6 lakh marginalised children.</li>
                        <li>• WASH (Water, Sanitation, Hygiene) integration.</li>
                    </ul>
                </div>
                <div class="border-t-4 border-blue-600 p-4 bg-gray-50">
                    <h3 class="font-bold text-blue-600 mb-2">Education</h3>
                    <ul class="text-sm space-y-2 text-gray-700">
                        <li>• Access to equitable, safe and quality learning.</li>
                        <li>• Focus on most marginalised communities.</li>
                        <li>• Targeting 2.5 lakh children.</li>
                    </ul>
                </div>
                <div class="border-t-4 border-orange-500 p-4 bg-gray-50">
                    <h3 class="font-bold text-orange-500 mb-2">Skill Building & Livelihood</h3>
                    <ul class="text-sm space-y-2 text-gray-700">
                        <li>• Strengthened social and economic capabilities.</li>
                        <li>• Targeting 2 lakh vulnerable families.</li>
                        <li>• Support for 10,000 youths.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="mt-16">
            <h2 class="text-3xl font-bold mb-8 border-b-2 border-gray-200">Alignment with SDGs</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="p-4 bg-green-600 text-white rounded shadow text-center">
                    <span class="block text-2xl font-bold">SDG 3</span>
                    <span class="text-xs uppercase">Good Health & Well-being</span>
                </div>
                <div class="p-4 bg-red-700 text-white rounded shadow text-center">
                    <span class="block text-2xl font-bold">SDG 4</span>
                    <span class="text-xs uppercase">Quality Education</span>
                </div>
                <div class="p-4 bg-orange-600 text-white rounded shadow text-center">
                    <span class="block text-2xl font-bold">SDG 5</span>
                    <span class="text-xs uppercase">Gender Equality</span>
                </div>
                <div class="p-4 bg-blue-800 text-white rounded shadow text-center">
                    <span class="block text-2xl font-bold">SDG 17</span>
                    <span class="text-xs uppercase">Partnerships for the Goals</span>
                </div>
            </div>
        </section>

        
    </div>

<%- include('partials/footer') %>
