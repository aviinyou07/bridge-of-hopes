        </a>

        <div class="hidden lg:flex items-center space-x-6 text-[11px] font-bold uppercase tracking-widest text-gray-700">
            <a href="/about" class="hover:text-red-600 transition-colors">About Us</a>
            <a href="/what_we_do" class="hover:text-red-600 transition-colors">What We Do</a>
            
            <a href="/donate" class="bg-[#e21f26] text-white px-6 py-2.5 font-bold hover:bg-red-700 transition-all shadow-sm">
                DONATE NOW
            </a>
        </div>

        <div class="lg:hidden flex items-center space-x-4">
 <a href="/donate" class="bg-[#e21f26] text-white px-4 py-2 text-[10px] font-bold uppercase">Donate</a>
            <button id="menu-btn" class="text-gray-600 focus:outline-none">
